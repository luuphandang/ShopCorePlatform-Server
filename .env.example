# Local development template. Copy to .env and adjust values.
# Production-only requirements live in .env.production.example.

NODE_ENV=development

PORT=3670

# Comma-separated list of allowed origins for CORS
CROSS_ORIGIN=http://localhost:3671,http://localhost:3672

RABBITMQ_URI=amqp://localhost

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=shopcore
DB_SCHEMA=public
DB_LOGGING=false
# DB_SYNCHRONIZE: must be "false" in production. Use migrations instead.
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

DEFAULT_PAGE=1
DEFAULT_PAGE_SIZE=10
GRAPHQL_PLAYGROUND=true

# AWS S3 (required in production; optional in dev — leave blank to disable file uploads)
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT=
SIGNED_URL_EXPIRES_IN=900

# RS256 keys — paste the PEM content with \n escapes or use multiline
JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_PRIVATE_KEY=
JWT_REFRESH_PUBLIC_KEY=
JWT_REFRESH_PRIVATE_KEY=

# Cookie domain (required in production; leave blank in dev for localhost)
# Production format: leading dot domain like ".shopcore.example.com"
COOKIE_DOMAIN=

# Redis (required in production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=60
REDIS_KEY_PREFIX=shopcore:

# Optional: error | warn | info | http | verbose | debug | silly
# Defaults: production=warn, development=debug
LOG_LEVEL=debug

# Optional: bcrypt salt rounds (1-31, default: 12)
BCRYPT_HASH_ROUNDS=12

# Optional: Rate limiting (default: 60 requests per 60 seconds)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Optional: GraphQL security (defaults: depth=7, complexity=1000)
GRAPHQL_MAX_DEPTH=7
GRAPHQL_MAX_COMPLEXITY=1000

# Metrics endpoint basic auth (required in production)
METRICS_USER=
METRICS_PASSWORD=
