NODE_ENV=string

PORT=number

# Comma-separated list of allowed origins for CORS
CROSS_ORIGIN=string

RABBITMQ_URI=string

DB_HOST=string
DB_PORT=number
DB_USER=string
DB_PASSWORD=string
DB_NAME=string
DB_SCHEMA=string
DB_LOGGING=boolean
DB_SYNCHRONIZE=boolean
DB_MIGRATIONS_RUN=boolean

DEFAULT_PAGE=number
DEFAULT_PAGE_SIZE=number
GRAPHQL_PLAYGROUND=boolean

AWS_S3_ACCESS_KEY=string
AWS_S3_SECRET_KEY=string
AWS_S3_REGION=string
AWS_S3_BUCKET_NAME=string
SIGNED_URL_EXPIRES_IN=number

JWT_ACCESS_PUBLIC_KEY=string
JWT_ACCESS_PRIVATE_KEY=string
JWT_REFRESH_PUBLIC_KEY=string
JWT_REFRESH_PRIVATE_KEY=string

# Optional: error | warn | info | http | verbose | debug | silly
# Defaults: production=warn, development=debug
LOG_LEVEL=string

# Optional: bcrypt salt rounds (1-31, default: 12)
BCRYPT_HASH_ROUNDS=12

# Optional: Rate limiting (default: 60 requests per 60 seconds)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Optional: GraphQL security (defaults: depth=7, complexity=1000)
GRAPHQL_MAX_DEPTH=7
GRAPHQL_MAX_COMPLEXITY=1000