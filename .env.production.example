# Production template. DO NOT commit a filled-in copy of this file.
# Source these values from AWS Secrets Manager / SSM Parameter Store / your CD pipeline (see task #33).
# Sentry is intentionally not wired up in this codebase yet (tasks 17-19 skipped); add SENTRY_DSN here when reversed.

NODE_ENV=production

PORT=3670

# Comma-separated list of allowed origins for CORS. No wildcards. No trailing slashes.
CROSS_ORIGIN=https://admin.shopcore.example.com,https://shopcore.example.com

RABBITMQ_URI=amqps://user:pass@rabbitmq.internal:5671

# === DB (all required) ===
DB_HOST=postgres.internal
DB_PORT=5432
DB_USER=shopcore_app
DB_PASSWORD=<from-secrets-manager>
DB_NAME=shopcore
DB_SCHEMA=public
DB_LOGGING=false
# Must stay "false" in production. envValidation rejects anything else.
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false

DEFAULT_PAGE=1
DEFAULT_PAGE_SIZE=10
# Disable in production — Apollo Sandbox / Playground are dev-only tools.
GRAPHQL_PLAYGROUND=false

# === AWS S3 (region + bucket required; access keys optional if running with IAM role) ===
# Leave AWS_S3_ACCESS_KEY/SECRET_KEY blank when the task/pod has an IAM role attached.
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=shopcore-prod-uploads
AWS_S3_ENDPOINT=
SIGNED_URL_EXPIRES_IN=900

# === JWT RS256 keys (required; rotate per task #35) ===
JWT_ACCESS_PUBLIC_KEY=<from-secrets-manager>
JWT_ACCESS_PRIVATE_KEY=<from-secrets-manager>
JWT_REFRESH_PUBLIC_KEY=<from-secrets-manager>
JWT_REFRESH_PRIVATE_KEY=<from-secrets-manager>

# === Cookie (required; must match regex /^\.[a-z0-9-]+(\.[a-z0-9-]+)*\.[a-z]{2,}$/ ) ===
COOKIE_DOMAIN=.shopcore.example.com

# === Redis (required) ===
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=<from-secrets-manager>
REDIS_TTL=60
REDIS_KEY_PREFIX=shopcore:

LOG_LEVEL=warn
BCRYPT_HASH_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
GRAPHQL_MAX_DEPTH=7
GRAPHQL_MAX_COMPLEXITY=1000

# === Metrics basic auth (required) ===
METRICS_USER=<from-secrets-manager>
METRICS_PASSWORD=<from-secrets-manager>
